---
const siteTitle = "outofnoise";

// 建立時間（可改）
const createdAt = new Date("2026-07-04");

// 模擬 posts（之後會變成真正文章）
const posts = [
  {
    title: "First Post",
    date: "2026-07-04",
    content: "This is a sample post for layout testing."
  }
];

// 字數統計
function wordCount(text) {
  return text.split(/\s+/).filter(Boolean).length;
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{siteTitle}</title>
  </head>

  <body style="margin: 0; font-family: sans-serif; background: #0b0b0f; color: #eaeaea;">

    <main style="max-width: 720px; margin: auto; padding: 40px;">

      <!-- Title -->
      <h1 style="font-size: 40px; margin-bottom: 10px;">
        {siteTitle}
      </h1>

      <!-- Meta -->
      <p>📅 Created: {createdAt.toDateString()}</p>

      <p>📝 Total posts: {posts.length}</p>

      <p>
        🔢 Total words:
        {posts.reduce((sum, post) => sum + wordCount(post.content), 0)}
      </p>

      <hr style="margin: 30px 0;" />

      <!-- Tags -->
      <section>
        <h2>🏷 Tags</h2>
        <p style="opacity: 0.6;">(coming soon)</p>
      </section>

      <hr style="margin: 30px 0;" />

      <!-- Posts -->
      <section>
        <h2>📝 Posts</h2>

        {posts.map((post) => (
          <article style="margin-bottom: 24px; padding: 16px; border: 1px solid #222; border-radius: 10px;">
            <h3 style="margin: 0 0 6px 0;">
              {post.title}
            </h3>

            <small style="opacity: 0.7;">
              {post.date}
            </small>

            <p>
              {post.content}
            </p>
          </article>
        ))}

      </section>

    </main>
  </body>
</html>
