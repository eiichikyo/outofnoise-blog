---
import { getCollection } from "astro:content";

const posts = await getCollection("blog");

// 建站時間
const createdAt = new Date("2026-07-04");

// 現在時間
const now = new Date();

// 運行天數
const daysRunning = Math.floor(
  (now.getTime() - createdAt.getTime()) /
  (1000 * 60 * 60 * 24)
);

// 總字數
const totalWords = posts.reduce((sum, post) => {
  return sum + post.body.split(/\s+/).filter(Boolean).length;
}, 0);
---

<!doctype html>
<html lang="zh">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width" />
<title>記憶消融前。</title>

<style>
body{
margin:0;
background:#0b0b0f;
color:#eaeaea;
font-family:sans-serif;

display:flex;
justify-content:center;
align-items:center;

height:100vh;
}

main{
text-align:center;
}

h1{
font-size:3rem;
font-weight:300;
margin-bottom:50px;
letter-spacing:4px;
}

.nav{
display:flex;
justify-content:center;
gap:40px;
margin-bottom:100px;
}

.nav a{
color:white;
text-decoration:none;
font-size:1.3rem;
padding:12px 24px;
border:1px solid #333;
border-radius:10px;
transition:.3s;
}

.nav a:hover{
background:white;
color:black;
}

.stats{
font-size:.8rem;
opacity:.45;
line-height:1.8;
}
</style>

</head>

<body>

<main>

<h1>記憶消融前。</h1>

<div class="nav">
<a href="/blog">📝 Posts</a>
<a href="/tags">🏷 Tags</a>
</div>

<div class="stats">
<div>Running {daysRunning} days</div>
<div>{posts.length} posts · {totalWords} words</div>
</div>

</main>

</body>
</html>