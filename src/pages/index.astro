---
import { getCollection } from "astro:content";

const posts = await getCollection("blog");

const siteTitle = "outofnoise";
const createdAt = new Date("2026-07-04");

// 按日期排序（新→舊）
posts.sort(
  (a, b) =>
    new Date(b.data.date).getTime() -
    new Date(a.data.date).getTime()
);

// 總字數
const totalWords = posts.reduce((sum, post) => {
  return (
    sum +
    post.body.split(/\s+/).filter(Boolean).length
  );
}, 0);
---

<!doctype html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width" />
<title>{siteTitle}</title>
</head>

<body style="margin:0;background:#0b0b0f;color:#eaeaea;font-family:sans-serif;">

<main style="max-width:720px;margin:auto;padding:40px;">

<h1>{siteTitle}</h1>

<p>📅 Created: {createdAt.toDateString()}</p>
<p>📝 Total posts: {posts.length}</p>
<p>🔢 Total words: {totalWords}</p>

<hr />

<h2>🏷 Tags</h2>
<p>(coming soon)</p>

<hr />

<h2>📝 Posts</h2>

{
posts.map((post)=>(
<article
style="margin-bottom:20px;padding:16px;border:1px solid #222;border-radius:10px;"
>

<h3>
<a
href={`/blog/${post.slug}`}
style="color:white;text-decoration:none;"
>
{post.data.title}
</a>
</h3>

<small>
  {new Date(post.data.date).toLocaleDateString("zh-TW", {
    year: "numeric",
    month: "long",
    day: "numeric",
  })}
</small>

</article>
))
}

</main>
</body>
</html>

